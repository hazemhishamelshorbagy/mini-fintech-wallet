<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Transfer | FastPay</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('partials/header') %>
    <main class="container">
      <section class="form-card">
        <h1>Create Transfer</h1>
        <p class="subtitle">Send money between wallets quickly and securely.</p>
        <% if (typeof error !== 'undefined') { %>
            <div class="error-message"><%= error %></div>
        <% } %>
        <form action="/createtransfer" method="POST">
            <label for="fromAccountId">From Account ID</label>
            <input type="text" id="fromAccountId" name="fromAccountId" required value="<%= formData ? formData.fromAccountId : '' %>">

            <label for="toAccountId">To Account ID</label>
            <input type="text" id="toAccountId" name="toAccountId" required value="<%= formData ? formData.toAccountId : '' %>">

            <label for="amount">Amount</label>
            <input type="number" id="amount" name="amount" required value="<%= formData ? formData.amount : '' %>">

            <input type="submit" value="Create Transfer">
        </form>
        <p class="form-note"><a href="/viewwallets" class="back-link">← Back to Wallets</a></p>
      </section>
    </main>
    <%- include('partials/footer') %>
</body>
</html>