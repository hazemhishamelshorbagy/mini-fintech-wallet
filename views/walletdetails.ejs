<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wallet Details | FastPay</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('partials/header') %>
    <main class="container">
      <section class="card">
        <div class="page-header">
          <h1 class="page-title">Wallet Details</h1>
          <p class="subtitle">Review the selected wallet information.</p>
        </div>
        <div class="summary-list">
          <li><strong>ID</strong><span><%= wallet.id %></span></li>
          <li><strong>Name</strong><span><%= wallet.customerName %></span></li>
          <li><strong>Balance</strong><span>$<%= wallet.balance %></span></li>
          <li><strong>Status</strong><span><%= wallet.status %></span></li>
        </div>
        <div class="page-actions">
          <a class="button" href="/viewwallets">Back To Wallets</a>
          <a class="button" href="/createtransfer">Create Transfer</a>
        </div>
      </section>
    </main>
    <%- include('partials/footer') %>
</body>
</html>