<!DOCTYPE html>
<html>

<head>
    <title>
        <%= title %>
    </title>
</head>

<body>

    <h1>Accounts</h1>

    <table border="1">
        <thead>
            <tr>
                <th>ID</th>
                <th>Customer</th>
                <th>Balance</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            <% accounts.forEach(account=> { %>

                <tr>
                    <td>
                        <%= account.id %>
                    </td>
                    <td>
                        <%= account.customerName %>
                    </td>
                    <td>
                        <%= account.balance %>
                    </td>
                    <td>
                        <%= account.status %>
                    </td>
                    <td>
                        <a href="/accountsdetail/<%= account.id %>">
                            View Details
                        </a>
                    </td>

                </tr>

                <% }) %>
        </tbody>

    </table>
<a href="/createaccount">
    Create New Account
</a>
</body>

</html>